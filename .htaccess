# ==================================================
# Negar acesso a arquivos e pastas sensíveis a partir da raiz.
# O ponto de entrada da aplicação é a pasta /public.
# ==================================================

<FilesMatch "^(\.env|\.env\..*|composer\.(json|lock)|bootstrap\.php|\.gitignore|README\.md|CHANGELOG\.md)$">
    Require all denied
</FilesMatch>

# Bloquear acesso direto a estes diretórios
RedirectMatch 403 ^/(src|config|database|logs|backups|scripts|docs|vendor)(/|$)
