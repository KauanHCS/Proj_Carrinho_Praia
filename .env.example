# ==================================================
# Aplicação
# ==================================================
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/Proj_Carrinho_Praia/public
TIMEZONE=America/Sao_Paulo

# ==================================================
# Banco de Dados
# ==================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sistema_carrinho
DB_USER=root
DB_PASS=

# ==================================================
# Segurança
# ==================================================
# Origens permitidas para CORS, separadas por vírgula. Use "*" só em DEV.
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW=300
CSRF_TOKEN_EXPIRY=3600

# ==================================================
# Logs / Cache
# ==================================================
LOG_LEVEL=debug
CACHE_ENABLED=true
CACHE_TTL=300
